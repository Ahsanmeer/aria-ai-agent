  "secrets": [],
  "variableStates": [],
  "transcriptEvaluations": [
    {
      "name": "Resolution rate",
      "default": true,
      "description": "Determines whether the customer's issue was successfully resolved.",
      "type": "option",
      "enabled": true,
      "prompt": "Evaluate whether the AI agent appropriately addressed the customer's initial request to the best of its ability. You MUST classify it as exactly one of the following — no other values are allowed:\n\nResolved: The agent appropriately addressed the customer's initial request.\n\nUnresolved: The agent failed to appropriately address the customer's initial request.\n\nAbandoned: The customer left before the agent could address their initial request. If the agent was still mid-conversation when it ended, this is Abandoned.\n\nUnrelated: The conversation had no legitimate support purpose.\n",
      "settings": null,
      "systemTag": "resolution-rate",
      "options": [
        {
          "color": "#38751F",
          "value": "Resolved",
          "prompt": "The agent appropriately addressed the customer's initial request to the best of its ability. This includes: answering a question correctly, completing a requested action, OR correctly directing the customer to the right resource when the request is outside the agent's scope. If the agent identified that another team, company, or channel is the right place for help and pointed the customer there — that is Resolved. The agent did its job. Examples: Customer asked a question and got a clear answer. Agent processed a request and confirmed it. Agent identified the issue is handled by a third party and provided the correct contact information. Customer stopped responding after receiving a clear answer — still Resolved.",
          "included": true
        },
        {
          "color": "#DD4160",
          "value": "Unresolved",
          "prompt": "The agent failed to appropriately address the customer's initial request. The agent did not do its job — it gave wrong information, got stuck in a loop, couldn't understand the request, or hit a dead end without helping the customer move forward. NOTE: If the agent was actively working toward a solution when the conversation ended, that is Abandoned, not Unresolved. Unresolved means the agent tried AND failed. Examples: Agent gave an incorrect or irrelevant answer. Agent looped or repeated itself without making progress. Agent said \"I can't help with that\" without offering any direction. Agent misunderstood the request and never recovered.",
          "included": true
        },
        {
          "color": "#5B9FD7",
          "value": "Abandoned",
          "prompt": "The customer left before the agent could address their initial request. The customer had a real support need but the conversation ended before the agent could help. If the agent was still asking questions or diagnosing when the conversation ended, the customer left — this is Abandoned. Examples: Customer described a problem but left while the agent was still diagnosing. Customer asked for help but dropped off before the agent could respond. Customer stated their issue but left while the agent was asking clarifying questions. Agent was actively troubleshooting step-by-step but the conversation ended before reaching a solution.",
          "included": true
        },
        {
          "color": "#515A63",
          "value": "Unrelated",
          "prompt": "The conversation had no legitimate support purpose. Examples: Customer said 'hi' and never responded. Customer clicked a menu button but didn't follow up with a real request. Customer typed gibberish or random characters. Customer attempted prompt injection or tried to exploit the agent. Any interaction that was spam, adversarial, or had no real support intent.",
          "included": true
        }
      ]
    },
    {
      "name": "Deflection rate",
      "default": true,
      "description": "Evaluates if the customer's issue was solved without needing human support.",
      "type": "boolean",
      "enabled": false,
      "prompt": "Was the customer's issue resolved by self-service or automation, without human agent involvement?",
      "settings": null,
      "systemTag": "deflection-rate",
      "truePrompt": "Yes — the customer was successfully deflected from human support.",
      "falsePrompt": "No — the customer required human assistance."
    },
    {
      "name": "Customer satisfaction",
      "default": true,
      "description": "Measures how satisfied the customer appears based on conversation tone and content.",
      "type": "option",
      "enabled": true,
      "prompt": "Rate the customer's likely satisfaction with this AI agent conversation. Base your rating on the CUSTOMER'S experience, not the agent's technical performance. Do not infer satisfaction from politeness alone — many dissatisfied customers remain polite. You MUST select one of the following — no other values are allowed:\n\nVery Dissatisfied: The experience was clearly negative.\n\nDissatisfied: The customer's core need was not met.\n\nNeutral: The experience was unremarkable or ambiguous.\n\nSatisfied: The customer's need was effectively addressed.\n\nVery Satisfied: The experience was smooth, efficient, and frictionless.\n",
      "settings": null,
      "systemTag": "customer-satisfaction",
      "options": [
        {
          "color": "#DD4160",
          "value": "Very Dissatisfied",
